[Unit]
Description=RunRace API
After=docker.service

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/runrace/backend
Environment=FIREBASE_SERVICE_ACCOUNT_PATH=/home/ec2-user/secrets/firebase-service-account.json
Environment=SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/runrace
Environment=SPRING_DATASOURCE_USERNAME=runrace
Environment=SPRING_DATASOURCE_PASSWORD=runrace
Environment=RUNRACE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,https://localhost,http://YOUR_PUBLIC_IP,http://YOUR_PUBLIC_IP:8081
ExecStart=/usr/bin/java -jar /home/ec2-user/runrace/backend/target/backend-0.0.1-SNAPSHOT.jar
Restart=on-failure

[Install]
WantedBy=multi-user.target
