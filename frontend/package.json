{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "next dev --hostname 0.0.0.0",
    "build": "node ../scripts/write-firebase-init.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync:android": "node ../scripts/ensure-cap-webdir.mjs && npx cap sync android",
    "frontend:deploy": "node ../scripts/deploy.mjs",
    "backend:deploy": "node ../scripts/deploy-backend.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/share": "^8.0.1",
    "exifr": "^7.1.3",
    "firebase": "^12.14.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-kakao-maps-sdk": "^1.2.1",
    "react-leaflet": "^5.0.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
